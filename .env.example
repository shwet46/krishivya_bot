TELEGRAM_TOKEN=your_telegram_bot_token

FEATHERLESS_API_KEY=your_featherless_api_key
FEATHERLESS_API_URL=https://api.featherless.ai/v1/chat/completions
FEATHERLESS_MULTIMODAL_MODEL=google/gemma-3-27b-it
FEATHERLESS_TEXT_MODEL=Qwen/Qwen2.5-72B-Instruct

SARVAM_API_KEY=your_sarvam_api_key
SARVAM_CHAT_API_URL=https://api.sarvam.ai/chat/completions
SARVAM_CHAT_MODEL=sarvam-30b
SARVAM_STT_API_URL=https://api.sarvam.ai/speech-to-text
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_API_URL=https://api.sarvam.ai/text-to-speech
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=meera

# Open-source STT model
OPEN_SOURCE_STT_MODEL=openai/whisper-tiny

# Open-source TTS models (Hugging Face model IDs)
OPEN_SOURCE_TTS_MODEL_EN=facebook/mms-tts-eng
OPEN_SOURCE_TTS_MODEL_HI=facebook/mms-tts-hin
OPEN_SOURCE_TTS_MODEL_MAR=facebook/mms-tts-mar
OPEN_SOURCE_TTS_MODEL_PAN=facebook/mms-tts-pan
OPEN_SOURCE_TTS_MODEL_BEN=facebook/mms-tts-ben